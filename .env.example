# NextAuth secret (v5: AUTH_SECRET). Also signs NIP-07 login challenge tokens.
AUTH_SECRET=
NEXTAUTH_SECRET=
NEXTAUTH_URL=
# relay-api origin (no trailing slash). In `next dev`, if unset, defaults to https://relay-api.bitmacro.io
# Loopback URLs (localhost / 127.0.0.1) in dev are ignored unless RELAY_API_ALLOW_LOCALHOST_UPSTREAM=1
NEXT_PUBLIC_API_URL=
# Server-side URL for relay-api (optional; falls back to NEXT_PUBLIC_API_URL)
# Use this if config PATCH times out (e.g. different Vercel region)
# RELAY_API_URL=
# Set to 1 only if you run relay-api on localhost and need the panel to use it in dev
# RELAY_API_ALLOW_LOCALHOST_UPSTREAM=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
# Obrigatório para criar/listar relays: mesma chave configurada no relay-api (Vercel env).
# Sem isto, POST /api/relays devolve 401 em local.
RELAY_API_KEY=
